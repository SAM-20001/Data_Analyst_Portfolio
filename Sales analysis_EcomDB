-- 1. Average employees salary

select avg(salary) from ecommerce_db.employees;

-- 2. Employee count by depatment

select department, count(emp_id) from ecommerce_db.employees group by department;

-- 3. Employees earning above average salary

select emp_name,salary from ecommerce_db.employees
 where salary > (select avg(salary) from ecommerce_db.employees);
 
  -- 4. Employees hire after 2020
 select emp_name, hire_date from ecommerce_db.employees where hire_date > 2020-12-31;
 
 
-- 5. Employees hire each year

select year(hire_date) as year, count(emp_id) from ecommerce_db.employees group by year;

-- 6. Department wise average salary

select department, avg(salary) as Average_salary
from ecommerce_db.employees 
group by department 
order by avg(salary);

-- 7. find salary distribution across departments

select department,
avg(salary) as average_salary,
min(salary) as minimum_salary,
max(salary) as maximum_salary,
sum(salary) as Total_salary
From ecommerce_db.employees
group by department;

-- 8. Top three employee with highest salary
select emp_name,
sum(salary) as Total_salary
From ecommerce_db.employees
group by emp_name
order by sum(salary) desc
limit 3;

